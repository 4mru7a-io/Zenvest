# ========================================
# Firebase Configuration
# ========================================
# Get these from Firebase Console: https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ========================================
# Stock Market APIs (Choose One or More)
# ========================================

# Alpha Vantage (Free - 5 requests/min)
# Get free key: https://www.alphavantage.co/api/
VITE_ALPHA_VANTAGE_KEY=demo

# Polygon.io (Recommended for Production)
# Get free tier: https://polygon.io/
VITE_POLYGON_API_KEY=your_polygon_key

# IEX Cloud (Reliable US stocks)
# Get free tier: https://iexcloud.io/
VITE_IEX_API_KEY=your_iex_key

# Finnhub (Real-time quotes & news)
# Get free tier: https://finnhub.io/
VITE_FINNHUB_API_KEY=your_finnhub_key

# ========================================
# AI Integration
# ========================================

# Claude API (for AI Assistant - optional)
# Get key: https://claude.ai/
VITE_CLAUDE_API_KEY=your_claude_api_key

# ========================================
# App Configuration
# ========================================

# App environment
VITE_ENV=development
VITE_API_PROVIDER=alphaVantage

# Enable/disable features
VITE_ENABLE_REAL_TRADING=false
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=fals
# ========================================
# Stock Market APIs (Choose One or More)
# ========================================

# Alpha Vantage (Free - 5 requests/min)
# Get free key: https://www.alphavantage.co/api/
VITE_ALPHA_VANTAGE_KEY=demo

# Polygon.io (Recommended for Production)
# Get free tier: https://polygon.io/
VITE_POLYGON_API_KEY=your_polygon_key

# IEX Cloud (Reliable US stocks)
# Get free tier: https://iexcloud.io/
VITE_IEX_API_KEY=your_iex_key

